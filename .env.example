# ============================================================================
# Powabase OSS — single-project stack configuration.
# 1) cp .env.example .env
# 2) python gen-keys.py        # appends the secret block to your .env
# 3) set your LLM key(s) (OPENAI_API_KEY at minimum)
# 4) docker compose up -d
# Secrets (POSTGRES_PASSWORD, JWT_SECRET, ANON_KEY, SERVICE_ROLE_KEY,
# DASHBOARD_USERNAME, DASHBOARD_PASSWORD, PG_META_CRYPTO_KEY, SECRET_KEY_BASE,
# API_KEY_ENCRYPTION_KEY) are written by gen-keys.py — do NOT set them by hand.
# ============================================================================

# --- Identity (informational only; the stack hardcodes 'default') ---
PROJECT_ID=default
PROJECT_NAME=Powabase

# --- Database ---
POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432
POSTGRES_MEM_LIMIT=1g
POSTGRES_CPUS=2

# --- Ports ---
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443

# --- API ---
PGRST_DB_SCHEMAS=public,storage

# --- Auth (GoTrue) ---
SITE_URL=http://localhost:3000
# keep the port in sync with KONG_HTTP_PORT above.
API_EXTERNAL_URL=http://localhost:8000
ADDITIONAL_REDIRECT_URLS=
JWT_EXPIRY=3600
# Signup is disabled by default. Create your first user via the admin API
# (service_role key) — or set DISABLE_SIGNUP=false and configure SMTP once the
# deployment is secured.
DISABLE_SIGNUP=true
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=false
ENABLE_ANONYMOUS_USERS=false
CORS_ALLOW_ORIGIN=*
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME=Powabase

# --- Storage (optional public URL; empty = base64 image delivery) ---
STORAGE_PUBLIC_URL=

# --- LLM / AI provider keys (BYOK — set your own; OPENAI_API_KEY is the minimum) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
MISTRAL_API_KEY=
COHERE_API_KEY=
VOYAGE_API_KEY=
JINA_API_KEY=
ZEROENTROPY_API_KEY=
LLAMAPARSE_API_KEY=
EXA_API_KEY=
FIRECRAWL_API_KEY=
PADDLEOCR_API_KEY=
PADDLEOCR_BASE_URL=
LIGHTON_API_KEY=
LIGHTON_BASE_URL=
